# ==================== БАЗОВЫЕ ТИПЫ ====================

type Query {
    users: [User]
    me: User
    groups: [Group]
    subjects: [Subject]
    scheduleByGroup(groupId: ID!): [ScheduleItem]
    scheduleForWeek(groupId: ID!, startDate: String!, endDate: String!): [ScheduleItem]
    scheduleForMe(startDate: String!, endDate: String!): [ScheduleItem]
    lecturesByGroup(groupId: ID!, startDate: String!, endDate: String!): [Lecture]
    lecturesByTeacher(teacherId: ID!, startDate: String!, endDate: String!): [Lecture]
    lecturesForMe(startDate: String!, endDate: String!): [Lecture]
}

type Mutation {
    register(input: RegisterInput!): User
    login(email: String!, password: String!): AuthResponse
    updateUser(id: ID!, name: String, email: String, role: String): User

    createGroup(name: String!, course: Int, specialty: String, faculty: String): Group
    addStudentToGroup(groupId: ID!, studentId: ID!): Group
    removeStudentFromGroup(groupId: ID!, studentId: ID!): Group

    createSubject(name: String!): Subject
    deleteSubject(id: ID!): Boolean

    createSchedule(input: CreateScheduleInput!): ScheduleItem
    createMultipleSchedules(input: [CreateScheduleInput!]!): [ScheduleItem!]!
    deleteSchedule(id: ID!): Boolean

    createLecture(input: CreateLectureInput!): Lecture

}

# ==================== ПОЛЬЗОВАТЕЛИ ====================

type User {
    id: ID
    name: String
    email: String
    role: String
}

type AuthResponse {
    token: String
    user: User
}

input RegisterInput {
    name: String!
    email: String!
    password: String!
    role: String!
}

# ==================== ГРУППЫ ====================

type Group {
    id: ID
    name: String
    course: Int
    specialty: String
    faculty: String
    students: [User]
}

# ==================== ПРЕДМЕТЫ ====================

type Subject {
    id: ID
    name: String
    requiredClassroomType: String
    teachers: [User]
    allowedClassrooms: [Classroom]
    groupHours: [SubjectGroupHours]
}

type SubjectGroupHours {
    group: Group!
    hours: Int!
}

# ==================== КАБИНЕТЫ ====================

type Classroom {
    id: ID!
    name: String
    capacity: Int
    type: String
}

# ==================== РАСПИСАНИЕ ====================

type ScheduleItem {
    id: ID
    date: String
    startTime: String
    endTime: String
    classroom: Classroom          # теперь объект, а не строка
    group: Group
    subject: Subject
    teacher: User
    homework: [Homework!]
}

input CreateScheduleInput {
    date: String!
    startTime: String!
    endTime: String!
    classroom: String             # для обратной совместимости (имя кабинета)
    classroomId: ID               # можно передавать ID кабинета
    groupId: ID!
    subjectId: ID!
    teacherId: ID!
}

# ==================== ДОМАШНИЕ ЗАДАНИЯ ====================

type Homework {
    id: ID!
    text: String
    date: String
    scheduleItem: ScheduleItem
    teacher: User
}

input CreateHomeworkInput {
    text: String!
    date: String!
    scheduleItemId: ID!
}

extend type Mutation {
    createHomework(input: CreateHomeworkInput!): Homework
    updateHomework(
        id: ID!
        text: String
        date: String
    ): Homework

    deleteHomework(id: ID!): Boolean
}

extend type Query {
    homeworkForSchedule(scheduleItemId: ID!): [Homework!]
}

# ==================== ЛЕКЦИИ ====================

type Lecture {
    id: ID
    date: String
    startTime: String
    endTime: String
    classroom: String
    title: String
    text: String
    group: Group
    subject: Subject
    teacher: User
}

input CreateLectureInput {
    date: String
    startTime: String
    endTime: String
    classroom: String
    groupId: ID
    subjectId: ID
    teacherId: ID
    title: String
    text: String
}

input GroupHoursInput {
    groupId: ID!
    hours: Int!
}

input CreateSubjectInput {
    name: String!
    requiredClassroomType: String
    allowedClassroomIds: [ID!]
    groupHours: [GroupHoursInput!]
    teacherIds: [ID!]
}

extend type Mutation {
    createSubjectWithDetails(input: CreateSubjectInput!): Subject
}

input AddSubjectDetailsInput {
    subjectId: ID!
    allowedClassroomIds: [ID!]
    groupHours: [GroupHoursInput!]
    teacherIds: [ID!]
}

extend type Mutation {
    addSubjectDetails(input: AddSubjectDetailsInput!): Subject
}

extend type Query {
    classrooms: [Classroom]
}

input CreateClassroomInput {
    name: String!
    capacity: Int
    type: String!   # "AUDITORIUM", "LABORATORY", "GYM"
}

extend type Mutation {
    createClassrooms(input: [CreateClassroomInput!]!): [Classroom!]!
}

input SubjectHoursInput {
    subjectId: ID!
    hours: Int!
}

input GroupScheduleInput {
    groupId: ID!
    subjectHours: [SubjectHoursInput!]!
}

input GenerateScheduleRequest {
    groups: [GroupScheduleInput!]!   # можно передать одну или несколько групп
    startDate: String!
    days: Int!
}

extend type Mutation {
    generateSchedule(request: GenerateScheduleRequest!): [ScheduleItem!]!
}